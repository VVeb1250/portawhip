{
  "name": "portawhip",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "Tools collector + context-cheap router for AI agent hosts: dispatches capability install to add-mcp/mise/asm, then routes the right one at the right moment instead of loading everything into context.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/VVeb1250/portawhip.git"
  },
  "scripts": {
    "load": "node scripts/load.mjs",
    "doctor": "node scripts/doctor.mjs",
    "connectors": "node scripts/link-connectors.mjs status",
    "connectors:link": "node scripts/link-connectors.mjs install",
    "hooks": "node scripts/link-hooks.mjs status",
    "hooks:link": "node scripts/link-hooks.mjs install",
    "sync-config": "node scripts/sync-config.mjs status",
    "sync-config:preview": "node scripts/sync-config.mjs preview",
    "surface": "node scripts/surface-inventory.mjs",
    "tui": "node scripts/tui.mjs",
    "bundles": "node scripts/bundles.mjs list",
    "bundles:status": "node scripts/bundles.mjs status",
    "bundles:select": "node scripts/bundles.mjs select",
    "test": "node --test core/router.test.mjs core/feedback.test.mjs core/stack-detect.test.mjs core/concept-vector.test.mjs core/eval-harvest.test.mjs core/enrich.test.mjs core/bundle-state.test.mjs scripts/link-hooks.test.mjs scripts/link-connectors.test.mjs scripts/sync-config.test.mjs adapters/hooks/universal-hook.test.mjs adapters/hooks/hook-stub.test.mjs",
    "route": "node core/router-cli.mjs route",
    "route:list": "node core/router-cli.mjs list",
    "route:eval": "node core/router-cli.mjs eval --engine hybrid",
    "route:compare": "node core/router-cli.mjs compare",
    "route:graph": "node core/router-cli.mjs graph-compile --out .hp-state/capability-graph.json",
    "route:enrich": "node core/router-cli.mjs enrich"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "add-mcp": "^1.13.0",
    "agent-skill-manager": "^2.7.0",
    "ansi-escapes": "^7.3.0",
    "cross-spawn": "^7.0.6",
    "ink": "^5.2.1",
    "js-yaml": "^4.1.0",
    "minisearch": "^7.2.0",
    "react": "^18.3.1"
  }
}
