{
  "name": "portawhip",
  "private": false,
  "type": "module",
  "version": "0.5.0",
  "description": "One control plane for the tools, skills, MCP servers, commands, agents and hooks your AI coding agents use: discover them once, then plug them into every host.",
  "license": "MIT",
  "homepage": "https://github.com/VVeb1250/portawhip#readme",
  "bugs": {
    "url": "https://github.com/VVeb1250/portawhip/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/VVeb1250/portawhip.git"
  },
  "keywords": [
    "ai-agents",
    "mcp",
    "model-context-protocol",
    "agent-tools",
    "agent-skills",
    "claude-code",
    "codex",
    "gemini-cli",
    "cursor",
    "developer-tools"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "portawhip": "scripts/portawhip.mjs"
  },
  "exports": {
    "./registry": "./core/registry/registry.mjs",
    "./registry/docs": "./core/registry/capability-docs.mjs",
    "./registry/kind": "./core/registry/capability-kind.mjs",
    "./registry/enrich": "./core/registry/enrich.mjs",
    "./state/config": "./core/state/config.mjs",
    "./state/stack-detect": "./core/state/stack-detect.mjs",
    "./state/bundle-state": "./core/state/bundle-state.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "adapters/",
    "core/",
    "CHANGELOG.md",
    "SECURITY.md",
    "recipes/",
    ".rulesync/",
    "rulesync.jsonc",
    "scripts/",
    "hooks.manifest.yaml",
    "recipe.yaml",
    "surface-matrix.yaml",
    "VISION.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "load": "node scripts/load.mjs",
    "doctor": "node scripts/doctor.mjs",
    "connectors": "node scripts/link/link-connectors.mjs status",
    "hooks": "node scripts/link/link-hooks.mjs status",
    "hooks:install": "node scripts/link/link-hooks.mjs install",
    "hooks:remove": "node scripts/link/link-hooks.mjs remove",
    "sync-config": "node scripts/sync/sync-config.mjs status",
    "sync-config:preview": "node scripts/sync/sync-config.mjs preview",
    "surface": "node scripts/surface-inventory.mjs",
    "import": "node scripts/sync/import-surfaces.mjs status",
    "import:preview": "node scripts/sync/import-surfaces.mjs preview",
    "hooks:embedded": "node scripts/embedded-hooks.mjs",
    "surface:sync": "node scripts/sync/sync-surfaces.mjs sync",
    "surface:sync:check": "node scripts/sync/sync-surfaces.mjs check",
    "sync:check": "node scripts/sync/reconcile.mjs check",
    "sync:verify": "node scripts/sync/reconcile.mjs verify",
    "sync:seed": "node scripts/sync/seed-rulesync.mjs preview",
    "tui": "node scripts/tui.mjs",
    "bundles": "node scripts/bundles.mjs list",
    "bundles:status": "node scripts/bundles.mjs status",
    "bundles:select": "node scripts/bundles.mjs select",
    "test": "node --test"
  },
  "dependencies": {
    "add-mcp": "^1.13.0",
    "agent-skill-manager": "^2.7.0",
    "ansi-escapes": "^7.3.0",
    "cross-spawn": "^7.0.6",
    "ink": "^5.2.1",
    "js-yaml": "^5.2.1",
    "react": "^18.3.1",
    "rulesync": "9.6.3"
  },
  "devDependencies": {
    "ai-config-sync-manager": "0.1.7"
  },
  "peerDependenciesMeta": {
    "portawhip-router": {
      "optional": true
    }
  }
}
