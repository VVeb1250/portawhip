{
  "$schema": "https://github.com/dyoshikawa/rulesync/releases/download/v9.6.3/config-schema.json",
  "targets": [
    "claudecode",
    "codexcli",
    "cursor",
    "copilot",
    "cline",
    "opencode",
    "goose",
    "amp",
    "pi",
    "qwencode",
    "zed",
    "junie"
  ],
  // "hooks" excluded: live-tested 2026-07-14, rulesync's hooks feature produces
  // an empty output for claudecode regardless of input schema (3 shapes tried,
  // undocumented format) — link-hooks.mjs owns the hooks key directly instead,
  // as a surgical writer on that disjoint region (see docs/writer-consolidation-plan.md).
  "features": ["rules", "ignore", "mcp", "commands", "subagents", "skills", "permissions"],
  "outputRoots": [
    "."
  ],
  "delete": false,
  "verbose": false,
  "silent": false,
  "global": false,
  "simulateCommands": false,
  "simulateSubagents": false,
  "simulateSkills": false,
  "gitignoreTargetsOnly": true
}
